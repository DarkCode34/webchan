{
  "manifest_version": 2,
  "name": "Kommentare",
  "version": "0.1",
  "description": "Anonyme Kommentare für Webseiten",
  "permissions": [
    "activeTab",
    "http://localhost:3000/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ]
}