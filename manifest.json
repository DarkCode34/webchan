{
  "manifest_version": 2,
  "name": "WebChan",
  "version": "0.1.0",
  "description": "Anonyme Kommentare für jede Webseite im Imageboard-Stil.",
  "browser_specific_settings": {
    "gecko": {
      "id": "webchan@darkcode34",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "http://localhost:3000/*",
    "https://webchan-9w51.onrender.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  }
}
